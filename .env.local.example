# Copy to .env.local and fill in real values. NEVER commit .env.local.

# --- Supabase (public site — safe to expose) --------------------------------
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- Supabase admin (SERVER ONLY — never prefix with NEXT_PUBLIC) -----------
# Supabase → Project Settings → API → service_role (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Auth.js / NextAuth (admin login) ---------------------------------------
# AUTH_SECRET: generate with `openssl rand -base64 33`
AUTH_SECRET=YOUR-RANDOM-SECRET
# Google OAuth — Google Cloud Console → APIs & Services → Credentials
AUTH_GOOGLE_ID=YOUR-GOOGLE-CLIENT-ID
AUTH_GOOGLE_SECRET=YOUR-GOOGLE-CLIENT-SECRET

# --- Admin allowlist (kept out of source; edit here / in Vercel only) -------
# Comma-separated Google OIDC "sub" ids allowed into /admin (stable account
# id, not email — read your own via GET /api/whoami after signing in).
# Optional: leaving it unset does NOT block Google sign-in, it just means
# no account is an admin yet.
ADMIN_GOOGLE_SUBS=104852001234567890123
